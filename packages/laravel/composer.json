{
  "name": "veribenim/laravel",
  "description": "Veribenim KVKK/GDPR çerez onayı SDK - Laravel entegrasyonu",
  "keywords": ["kvkk", "gdpr", "cookie", "consent", "veribenim", "laravel"],
  "homepage": "https://veribenim.com",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.1",
    "veribenim/php-sdk": "^0.1",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Veribenim\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Veribenim\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Veribenim\\Laravel\\VeribenimServiceProvider"
      ],
      "aliases": {
        "Veribenim": "Veribenim\\Laravel\\VeribenimFacade"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
