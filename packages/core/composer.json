{
  "name": "veribenim/php-sdk",
  "description": "Veribenim KVKK/GDPR çerez onayı SDK - PHP Core",
  "keywords": ["kvkk", "gdpr", "cookie", "consent", "veribenim"],
  "homepage": "https://veribenim.com",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Veribenim\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Veribenim\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
